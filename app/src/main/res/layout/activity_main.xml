<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="32dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/pulseDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/pulse_dot"
            android:visibility="gone" />

        <TextView
            android:id="@+id/monitoringLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            app:fontFamily="@font/pretendard_bold"
            android:letterSpacing="0.02"
            android:text="@string/monitor_watching_label"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/routeText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:singleLine="true"
            app:fontFamily="@font/pretendard_bold"
            android:letterSpacing="0.02"
            android:text="@string/monitor_route"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/idleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fontFamily="@font/pretendard_medium"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/monitor_idle"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/heroNumberRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:visibility="gone">

            <TextView
                android:id="@+id/heroNumberText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:fontFamily="@font/pretendard_extrabold"
                android:includeFontPadding="false"
                android:textColor="@color/accent"
                android:textSize="80sp"
                tools:text="8" />

            <TextView
                android:id="@+id/heroUnitText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:layout_marginStart="4dp"
                app:fontFamily="@font/pretendard_bold"
                android:text="@string/monitor_eta_unit"
                android:textColor="@color/accent"
                android:textSize="20sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/heroCaptionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:fontFamily="@font/pretendard_medium"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="15sp"
            android:visibility="gone"
            tools:text="20개 정류장 전 · 잔여좌석 12" />
    </LinearLayout>

    <RadioGroup
        android:id="@+id/vehicleRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_segmented"
        android:checkedButton="@id/firstVehicleRadio"
        android:orientation="horizontal"
        android:padding="4dp">

        <RadioButton
            android:id="@+id/firstVehicleRadio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/selector_segment_background"
            android:button="@null"
            app:fontFamily="@font/pretendard_bold"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="@string/first_vehicle_alarm"
            android:textColor="@color/selector_segment_text"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/secondVehicleRadio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/selector_segment_background"
            android:button="@null"
            app:fontFamily="@font/pretendard_bold"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="@string/second_vehicle_alarm"
            android:textColor="@color/selector_segment_text"
            android:textSize="14sp" />

    </RadioGroup>

    <Button
        android:id="@+id/startButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_button_primary"
        app:fontFamily="@font/pretendard_bold"
        android:paddingVertical="16dp"
        android:text="@string/start_monitoring"
        android:textAllCaps="false"
        android:textColor="@color/on_accent"
        android:textSize="16sp" />

    <Button
        android:id="@+id/stopButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_button_outline"
        app:fontFamily="@font/pretendard_bold"
        android:paddingVertical="16dp"
        android:text="@string/stop_monitoring"
        android:textAllCaps="false"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="16sp"
        android:visibility="gone" />

</LinearLayout>
