<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/monitor_title"
        android:textAppearance="?attr/textAppearanceHeadlineSmall" />

    <TextView
        android:id="@+id/routeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/monitor_route"
        android:textAppearance="?attr/textAppearanceBodyLarge" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:minHeight="180dp"
        android:lineSpacingExtra="6dp"
        android:text="@string/monitor_idle"
        android:textAppearance="?attr/textAppearanceBodyMedium" />

    <RadioGroup
        android:id="@+id/vehicleRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:checkedButton="@id/firstVehicleRadio"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/firstVehicleRadio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/first_vehicle_alarm" />

        <RadioButton
            android:id="@+id/secondVehicleRadio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/second_vehicle_alarm" />

    </RadioGroup>

    <Button
        android:id="@+id/startButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/start_monitoring" />

    <Button
        android:id="@+id/stopButton"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/stop_monitoring" />

</LinearLayout>
